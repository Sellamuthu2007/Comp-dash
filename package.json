{
  "name": "comp-dash",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:mobile": "expo start --dev-client",
    "dev:web": "npm run dev -w apps/web",
    "build:mobile": "expo build:android && expo build:ios",
    "build:web": "next build apps/web && next export -o out",
    "lint": "eslint . --ext .tsx,.ts",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.56.0",
    "husky": "^9.0.0",
    "prettier": "^3.2.0",
    "turbo": "^1.12.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}